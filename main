import subprocess
import os

def ejecutar_script(nombre_script):
    """Función para ejecutar scripts de Python localizados en la carpeta /src."""
    ruta = os.path.join("src", nombre_script)
    print(f"--- Ejecutando {nombre_script} ---")
    resultado = subprocess.run(["python", ruta], capture_output=True, text=True)
    if resultado.returncode == 0:
        print(f"Éxito: {nombre_script}")
    else:
        print(f"Error en {nombre_script}: {resultado.stderr}")

if __name__ == "__main__":
    print("🚀 Iniciando Pipeline de Datos Futbolísticos...")
    
    # 1. Ingesta de noticias y análisis de sentimiento
    ejecutar_script("Ingesta.py")
    ejecutar_script("Procesar.py")
    
    # 2. Ingesta de estadísticas deportivas reales
    ejecutar_script("Ingesta_Stats.py")
    
    print("\n✅ Pipeline completado con éxito. Ejecuta 'streamlit run src/app.py' para ver el dashboard.")